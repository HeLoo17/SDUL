# Public port exposed by the LXC container.
FRONTEND_PORT=80

# Leave empty in Docker. The frontend calls same-origin /api and /socket.io,
# and Nginx proxies those requests to the private backend service.
VITE_API_URL=

# Must match backend/.env DASHBOARD_API_KEY.
DASHBOARD_API_KEY=

# These are only used on the very first `docker compose up` to initialise the DB.
# After that, InfluxDB reads them from its own internal config.
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=

# Must match the values in backend/.env
INFLUXDB_ORG=lab-d-proxmox
INFLUXDB_BUCKET=proxmox_history
INFLUXDB_TOKEN=
